#!/usr/bin/env python3
"""label — internal toolkit for the brother-label clerk.

Drives the Brother VC-500W (CUPS queue `brother`) plus inventory and icon-gen
integrations. Invoked by the brother-label agent to handle requests from other
agents; not a public CLI yet.
"""

import argparse
import base64
import hashlib
import json
import os
import pathlib
import subprocess
import sys
import tempfile
import textwrap
import time
import urllib.error
import urllib.parse
import urllib.request

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent))
import brother_print

PRINTER = "brother"
USE_CUPS = os.environ.get("LABEL_USE_CUPS") == "1"  # fallback: old qemu/proxy path
PRINT_CUT = "full"   # set from CLI args in main()
PRINT_MODE = brother_print.DEFAULT_MODE
DPI = 320
WIDTH_IN = 1.0
WIDTH_PX = int(WIDTH_IN * DPI)
ROOT = pathlib.Path(__file__).resolve().parent.parent
CACHE = ROOT / "cache"
ICON_CACHE = CACHE / "icons"
INVENTORY_BASE = os.environ.get("INVENTORY_API_BASE", "http://centurion:30191/api")
OPENROUTER_KEY = os.environ.get("OPENROUTER_API_KEY") or os.environ.get("OPENAI_API_KEY")
IMAGE_MODEL = "google/gemini-2.5-flash-image"
FONT = "Adwaita-Sans-Bold"
SEARXNG_BASE = os.environ.get("SEARXNG_BASE", "http://centurion:30502")


def die(msg, code=1):
    print(f"label: {msg}", file=sys.stderr)
    sys.exit(code)


def run(cmd, **kw):
    return subprocess.run(cmd, check=True, **kw)


def _as_float(val):
    """Parse an XML numeric field to float, or None if missing/garbled."""
    try:
        return float(val) if val else None
    except (TypeError, ValueError):
        return None


def _as_int(val, default=0):
    """Parse an XML numeric field to int, or `default` if missing/garbled."""
    try:
        return int(val) if val else default
    except (TypeError, ValueError):
        return default


def lp(path: pathlib.Path):
    """Print a file. Native AppSocket by default; CUPS queue if LABEL_USE_CUPS=1."""
    path = pathlib.Path(path)
    if USE_CUPS:
        out = subprocess.run(["lp", "-d", PRINTER, str(path)], capture_output=True, text=True, check=True)
        print(out.stdout.strip())
        return
    try:
        brother_print.send(str(path), mode=PRINT_MODE, cut=PRINT_CUT)
    except brother_print.PrinterError as e:
        die(f"print failed: {e}")
    except OSError as e:
        die(f"printer unreachable: {e} (try `label reset`, or LABEL_USE_CUPS=1 to use the CUPS fallback)")
    print(f"printed {path.name} (native, mode={PRINT_MODE}, cut={PRINT_CUT})")


def cmd_print(args):
    path = pathlib.Path(args.file).expanduser().resolve()
    if not path.exists():
        die(f"file not found: {path}")
    lp(path)


def make_text_png(text: str, out_path: pathlib.Path, font_size: int):
    out_path.parent.mkdir(parents=True, exist_ok=True)
    lines = textwrap.wrap(text, width=max(6, int(WIDTH_PX / (font_size * 0.6))))
    body = "\n".join(lines) if lines else text
    height = max(160, (font_size + 12) * max(1, len(lines)) + 40)
    run([
        "magick", "-size", f"{WIDTH_PX}x{height}",
        "xc:white", "-gravity", "center",
        "-font", FONT, "-pointsize", str(font_size),
        "-fill", "black",
        "-annotate", "+0+0", body,
        "-density", str(DPI),
        str(out_path),
    ])


def cmd_text(args):
    h = hashlib.sha1(f"{args.size}:{args.text}".encode()).hexdigest()[:12]
    out = CACHE / "text" / f"{h}.png"
    make_text_png(args.text, out, args.size)
    print(out)
    if not args.no_print:
        lp(out)


def gen_image(prompt: str, out_path: pathlib.Path):
    out_path.parent.mkdir(parents=True, exist_ok=True)
    if OPENROUTER_KEY:
        try:
            _gen_image_openrouter(prompt, out_path)
            return
        except urllib.error.HTTPError as e:
            # Any auth/credit failure means OpenRouter is unusable — fall back to
            # comfy-openai instead of crashing. (401 = invalid/revoked key,
            # 402 = no credits, 403 = forbidden.)
            if e.code in (401, 402, 403):
                reason = {401: "invalid/revoked key", 402: "no credits", 403: "forbidden"}[e.code]
                print(f"OpenRouter {e.code} ({reason}) — falling back to comfy-openai",
                      file=sys.stderr)
            else:
                raise
        except urllib.error.URLError as e:
            # Connection-level failure (DNS, refused, timeout): OpenRouter is
            # unreachable. comfy-openai lives on the LAN, so prefer it over
            # crashing just because the internet path is down. HTTPError is
            # handled above (it subclasses URLError), so this catches only the
            # non-HTTP transport errors.
            print(f"OpenRouter unreachable ({e.reason}) — falling back to comfy-openai",
                  file=sys.stderr)
    try:
        _gen_image_comfy(prompt, out_path)
        return
    except Exception as e:
        print(f"comfy-openai failed ({e}) — falling back to SearXNG image search", file=sys.stderr)
    _gen_image_searxng(prompt, out_path)


def _gen_image_openrouter(prompt: str, out_path: pathlib.Path):
    body = json.dumps({
        "model": IMAGE_MODEL,
        "modalities": ["image", "text"],
        "messages": [{"role": "user", "content": prompt}],
    }).encode()
    req = urllib.request.Request(
        "https://openrouter.ai/api/v1/chat/completions",
        data=body,
        headers={"Authorization": f"Bearer {OPENROUTER_KEY}", "Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=180) as resp:
        data = json.load(resp)
    images = data.get("choices", [{}])[0].get("message", {}).get("images") or []
    if not images:
        die(f"image generation returned no image: {json.dumps(data)[:300]}")
    url = images[0]["image_url"]["url"]
    out_path.write_bytes(base64.b64decode(url.split(",", 1)[1]))


def _gen_image_comfy(prompt: str, out_path: pathlib.Path):
    body = json.dumps({
        "model": "z-image-turbo",
        "prompt": prompt,
        "n": 1,
        "size": "1024x1024",
        "response_format": "b64_json"
    }).encode()
    req = urllib.request.Request(
        "http://192.168.8.158:30385/v1/images/generations",
        data=body,
        headers={"Content-Type": "application/json"}
    )
    with urllib.request.urlopen(req, timeout=180) as resp:
        data = json.load(resp)
    images = data.get("data", [])
    if not images:
        # Raise (don't die): gen_image catches this to fall through to the
        # SearXNG last resort, matching the documented backend chain. die()
        # would exit the process and strand the fallback.
        raise RuntimeError(f"comfy-openai returned no image: {json.dumps(data)[:300]}")
    b64 = images[0].get("b64_json")
    if not b64:
        raise RuntimeError("comfy-openai missing b64_json")
    out_path.write_bytes(base64.b64decode(b64))


def _valid_raster(data: bytes, min_side: int = 48) -> bool:
    """True if `data` decodes as a real image at least `min_side` px per side.

    Guards the image-search fallback against the obvious junk it can otherwise
    write verbatim: HTML error pages, empty bodies, and tracking-pixel-sized
    images. It cannot tell a *wrong* icon from a right one (that needs eyes) —
    callers must still treat fallback results as unverified."""
    if len(data) < 256:
        return False
    try:
        with tempfile.NamedTemporaryFile(suffix=".img") as tf:
            tf.write(data)
            tf.flush()
            out = subprocess.run(
                ["identify", "-format", "%w %h", f"{tf.name}[0]"],
                capture_output=True, text=True,
            )
        if out.returncode != 0:
            return False
        w, h = (int(x) for x in out.stdout.split()[:2])
        return min(w, h) >= min_side
    except Exception:
        return False


def _gen_image_searxng(prompt: str, out_path: pathlib.Path):
    search_url = (
        f"{SEARXNG_BASE}/search?q={urllib.parse.quote(prompt)}"
        "&categories=images&format=json"
    )
    with urllib.request.urlopen(search_url, timeout=10) as resp:
        data = json.load(resp)
    results = data.get("results", [])
    if not results:
        die(f"SearXNG returned no image results for: {prompt!r}")
    # Prefer direct image URLs, deprioritize known low-quality sources
    skip_domains = {"artic.edu", "alamy.com", "dreamstime.com", "shutterstock.com", "getty",
                    "devicons", "lucide-static", "flaticon.com", "unsplash.com", "vectorstock"}
    candidates = []
    for r in results[:20]:
        url = r.get("img_src") or r.get("url", "")
        if not url:
            continue
        if any(d in url for d in skip_domains):
            candidates.append((1, url))
        elif any(url.lower().endswith(ext) for ext in (".png", ".jpg", ".jpeg", ".webp", ".svg")):
            candidates.append((0, url))
        else:
            candidates.append((2, url))
    candidates.sort(key=lambda x: x[0])
    for _, img_url in candidates[:8]:
        print(f"SearXNG fallback: {img_url}", file=sys.stderr)
        try:
            req = urllib.request.Request(img_url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = resp.read()
            if not _valid_raster(data):
                print("  skipping (not a usable image — HTML/empty/too small)", file=sys.stderr)
                continue
            out_path.write_bytes(data)
            print("  NOTE: unverified image-search result — eyeball it before printing",
                  file=sys.stderr)
            return
        except Exception as e:
            print(f"  skipping ({e})", file=sys.stderr)
            continue
    die(f"SearXNG: all candidate URLs failed for {prompt!r}")


def to_square_label(src: pathlib.Path, dst: pathlib.Path):
    run([
        "magick", str(src),
        "-resize", f"{WIDTH_PX}x{WIDTH_PX}^",
        "-gravity", "center",
        "-extent", f"{WIDTH_PX}x{WIDTH_PX}",
        "-density", str(DPI),
        str(dst),
    ])


def cmd_icon(args):
    h = hashlib.sha1(args.prompt.encode()).hexdigest()[:12]
    raw = CACHE / "gen" / f"{h}.png"
    label = CACHE / "gen" / f"{h}_label.png"
    if not raw.exists() or args.regen:
        print(f"generating icon ({h})...", file=sys.stderr)
        gen_image(args.prompt, raw)
    to_square_label(raw, label)
    print(label)
    if not args.no_print:
        lp(label)


def compose_drawer_sticker(icon: pathlib.Path, name: str, out: pathlib.Path):
    icon_h = 260
    text_h = 100
    out.parent.mkdir(parents=True, exist_ok=True)
    # Scale font size down for longer names
    fontsize = 52 if len(name) <= 12 else (40 if len(name) <= 18 else 30)
    run([
        "magick",
        "(", str(icon), "-resize", f"{WIDTH_PX}x{icon_h}^",
            "-gravity", "center", "-extent", f"{WIDTH_PX}x{icon_h}", ")",
        "(", "-size", f"{WIDTH_PX}x{text_h}", "xc:white",
            "-gravity", "center",
            "-font", FONT, "-pointsize", str(fontsize), "-fill", "black",
            "-annotate", "+0+0", name,
        ")",
        "-append",
        "-density", str(DPI),
        str(out),
    ])


def cmd_drawer(args):
    name = args.name
    prompt = (
        f"A clean minimal flat icon representing '{name}'. "
        "Centered composition, white background, simple shapes, "
        "no text, no border, no shadows. Sticker-friendly, bold silhouette."
    )
    h = hashlib.sha1(name.lower().encode()).hexdigest()[:12]
    icon_raw = CACHE / "drawer" / f"{h}_raw.png"
    out = CACHE / "drawer" / f"{h}.png"
    if not icon_raw.exists() or args.regen:
        print(f"generating icon for {name!r}...", file=sys.stderr)
        gen_image(prompt, icon_raw)
    compose_drawer_sticker(icon_raw, name, out)
    print(out)
    if not args.no_print:
        lp(out)


def fetch_tags():
    url = f"{INVENTORY_BASE}/tags"
    with urllib.request.urlopen(url, timeout=10) as resp:
        return json.load(resp)


def resolve_tag(ref: str):
    tags = fetch_tags()
    for t in tags:
        if t.get("id") == ref:
            return t
    matches = [t for t in tags if t.get("name", "").lower() == ref.lower()]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        die(f"multiple tags match name {ref!r}; pass the uuid instead")
    partial = [t for t in tags if ref.lower() in t.get("name", "").lower()]
    if len(partial) == 1:
        return partial[0]
    if len(partial) > 1:
        names = ", ".join(t["name"] for t in partial[:8])
        die(f"ambiguous tag {ref!r}: matches {names}")
    die(f"tag not found: {ref!r}")


def compose_tag_sticker(icon: pathlib.Path, tag: dict, out: pathlib.Path):
    icon_h = 300
    text_h = 180
    out.parent.mkdir(parents=True, exist_ok=True)
    run([
        "magick",
        "(", str(icon), "-resize", f"{WIDTH_PX}x{icon_h}^",
            "-gravity", "center", "-extent", f"{WIDTH_PX}x{icon_h}", ")",
        "(", "-size", f"{WIDTH_PX}x{text_h}", "xc:white",
            "-gravity", "north",
            "-font", FONT, "-pointsize", "44", "-fill", "black",
            "-annotate", "+0+18", tag["name"],
            "-gravity", "south",
            "-font", "Adwaita-Sans", "-pointsize", "18", "-fill", "gray50",
            "-annotate", "+0+10", tag["id"][:8],
        ")",
        "-append",
        "-density", str(DPI),
        str(out),
    ])


def cmd_tag(args):
    tag = resolve_tag(args.tag)
    icon_path = ICON_CACHE / f"{tag['id']}.png"
    if not icon_path.exists() or args.regen:
        prompt = (
            f"A clean minimal flat icon representing '{tag['name']}'. "
            "Centered composition, white background, vibrant colors, simple shapes, "
            "no text, no border, no shadows. Sticker-friendly, bold silhouette."
        )
        print(f"generating icon for {tag['name']!r}...", file=sys.stderr)
        gen_image(prompt, icon_path)
    sticker = CACHE / "tags" / f"{tag['id']}.png"
    compose_tag_sticker(icon_path, tag, sticker)
    print(sticker)
    if not args.no_print:
        lp(sticker)


def cmd_tags(args):
    """List inventory tags."""
    tags = fetch_tags()
    tags.sort(key=lambda t: t.get("name", ""))
    for t in tags:
        print(f"{t['id'][:8]}  {t.get('item_count', '?'):>4}  {t.get('name', '')}")


def _zink_query(path: str, timeout: float = 8.0) -> bytes:
    """Read a Brother AppSocket XML resource (delegates to the native driver)."""
    return brother_print.query(path, timeout=timeout)


def _xml_field(blob: bytes, tag: str) -> str | None:
    return brother_print.xml_field(blob, tag)


def cmd_status(args):
    if getattr(args, "json", False):
        out = {"reachable": False, "idle": False}
        try:
            status = _zink_query("/status.xml")
            config = _zink_query("/config.xml")
        except Exception as e:
            out["error"] = str(e)
            print(json.dumps(out))
            sys.exit(1)
        remain = _xml_field(status, "remain")
        initial = _xml_field(config, "media_length_initial")
        out.update({
            "reachable": True,
            "state": _xml_field(status, "print_state"),
            "idle": _xml_field(status, "print_state") == "IDLE",
            "last_job_stage": _xml_field(status, "print_job_stage"),
            "last_job_error": _xml_field(status, "print_job_error"),
            "tape_remaining_in": _as_float(remain),
            "tape_initial_in": _as_float(initial),
            "prints_this_cassette": _as_int(_xml_field(status, "print_num")),
        })
        print(json.dumps(out))
        sys.exit(0 if out["idle"] else 1)

    # The CUPS queue only reflects reality in the fallback path; in native mode
    # its "idle / enabled" line is misleading (it's unrelated to the printer's
    # actual reachability), so only show it when LABEL_USE_CUPS=1.
    if USE_CUPS:
        print("=== CUPS queue ===", flush=True)  # flush so it precedes lpstat's direct writes
        subprocess.run(["lpstat", "-p", PRINTER])
        subprocess.run(["lpstat", "-W", "not-completed", "-o", PRINTER])
        print()

    try:
        status = _zink_query("/status.xml")
        config = _zink_query("/config.xml")
    except Exception as e:
        print(f"zink query failed: {e}")
        return

    def f(blob, tag):
        return _xml_field(blob, tag) or "?"

    initial = f(config, "media_length_initial")
    remain = f(status, "remain")
    try:
        pct = f"{float(remain) / float(initial) * 100:.0f}%"
    except (ValueError, ZeroDivisionError):
        pct = "?"

    print("=== printer ===")
    print(f"  state          : {f(status, 'print_state')}, last job {f(status, 'print_job_stage')} (err: {f(status, 'print_job_error')})")
    print(f"  prints (cassette): {f(status, 'print_num')}")
    print(f"  tape remaining : {remain}\" of {initial}\"  ({pct})")
    print(f"  power          : capacity {f(status, 'capacity')}, online {f(status, 'online')}")
    print("\n=== cassette ===")
    print(f"  width (tape/media): {f(config, 'width_inches')}\" / {f(config, 'width_inches_media')}\"")
    print(f"  topcoat / adhesive: {f(config, 'topcoat')} / {f(config, 'adhesive')}")
    print(f"  media id          : {f(config, 'media_id')}")
    print(f"  cassette s/n      : {f(config, 'cassette_sn')}")
    print("\n=== device ===")
    print(f"  model     : Brother VC-500W ({f(config, 'model_name')})")
    print(f"  serial    : {f(config, 'serial_number')}")
    print(f"  firmware  : {f(config, 'fw_version_number')}")
    print(f"  mac       : {f(config, 'wlan0_mac_address')}")
    print(f"  dpi       : {f(config, 'crossweb_dpi')}")


def cmd_waybar(args):
    """Emit a JSON object for a waybar custom module."""
    icon = "\U000f02f6"  # nf-md-printer-3d (works as a generic printer glyph)
    try:
        status = _zink_query("/status.xml", timeout=3.0)
        config = _zink_query("/config.xml", timeout=3.0)
    except Exception:
        print(json.dumps({"text": "", "class": "hidden"}))
        return

    def f(blob, tag):
        return _xml_field(blob, tag)

    remain = f(status, "remain")
    initial = f(config, "media_length_initial")
    try:
        pct = float(remain) / float(initial) * 100
    except (TypeError, ValueError, ZeroDivisionError):
        print(json.dumps({"text": "", "class": "hidden"}))
        return

    state = (f(status, "print_state") or "?").upper()
    klass = "normal"
    if state != "IDLE":
        klass = "printing"
    elif pct < 10:
        klass = "critical"
    elif pct < 25:
        klass = "warning"

    bar_len = 4
    filled = max(0, min(bar_len, round(pct / 100 * bar_len)))
    bar = "█" * filled + "░" * (bar_len - filled)
    text = f"{icon} {bar} {pct:.0f}%"

    tooltip = (
        f"Brother VC-500W ({f(config, 'model_name') or '?'})\n"
        f"State: {state}, last job {f(status, 'print_job_stage') or '?'} "
        f"(err: {f(status, 'print_job_error') or '?'})\n"
        f"Tape: {remain}\" of {initial}\" ({pct:.1f}%)\n"
        f"Prints (cassette): {f(status, 'print_num') or '?'}\n"
        f"Cassette: {f(config, 'topcoat') or '?'} / {f(config, 'adhesive') or '?'}, "
        f"media {f(config, 'media_id') or '?'}\n"
        f"Firmware: {f(config, 'fw_version_number') or '?'}"
    )

    print(json.dumps({
        "text": text,
        "tooltip": tooltip,
        "class": klass,
        "percentage": round(pct),
    }))


def cmd_cut(args):
    print("Auto-cut is native: every print sends <cutmode>full</cutmode> in the print header.")
    print("Disable per-job with `--no-cut` (e.g. `label print --no-cut foo.png`).")
    print("The old cups-proxy auto-cut path is only used when LABEL_USE_CUPS=1.")


def cmd_send(args):
    path = pathlib.Path(args.file).expanduser().resolve()
    if not path.exists():
        die(f"file not found: {path}")
    lp(path)


def cmd_reset(args):
    """Clear a stuck job by acquiring + releasing the printer lock."""
    before = brother_print.tape_remaining()
    try:
        status = brother_print.reset()
    except OSError as e:
        die(f"printer unreachable: {e}\nIf it stays stuck, power-cycle the printer.")
    state = brother_print.xml_field(status, "print_state") or "?"
    stage = brother_print.xml_field(status, "print_job_stage") or "?"
    print(f"reset attempted. print_state={state}, stage={stage}")
    if state != "IDLE":
        print("Still not IDLE — a physical power-cycle may be required.")
        return
    # After clearing an EJECT JAM the firmware sometimes flushes the jammed
    # job's queued raster as a *delayed* print. Watch the tape gauge briefly so
    # the caller knows whether the label already came out (don't reprint!).
    if before is None:
        return
    for _ in range(8):
        time.sleep(2)
        now = brother_print.tape_remaining()
        if now is not None and now < before:
            print(f'NOTE: a queued raster flushed as a delayed print '
                  f'(tape {before}" -> {now}") — the label came out, do NOT reprint.')
            return
    print('No delayed print detected (tape gauge unchanged) — '
          'if your label never fed, reprint it.')


def sheet_argv(args):
    """Build the argv for bin/label-sheet from parsed `sheet` args (pure; tested)."""
    sheet_bin = pathlib.Path(__file__).resolve().parent / "label-sheet"
    argv = [sys.executable, str(sheet_bin), *args.images]
    if args.demo:
        argv.append("--demo")
    argv += ["--tile", str(args.tile)]
    if not args.ruler:
        argv.append("--no-ruler")
    if args.do_print:
        argv.append("--print")
    return argv


def cmd_sheet(args):
    """Pack multiple pictograms onto one strip (one job, one cut) — tape-sparing.

    Thin delegation to bin/label-sheet, which owns packing, the real-size preview,
    and the print. Batching N stickers into a single cut sidesteps the intrinsic
    consecutive-cut eject jam (see docs/RFC-002)."""
    if not args.images and not args.demo:
        die("give image files or --demo")
    subprocess.run(sheet_argv(args), check=True)


def main():
    global PRINT_CUT, PRINT_MODE

    p = argparse.ArgumentParser(prog="label")
    sub = p.add_subparsers(dest="cmd", required=True)

    # Shared print options for every subcommand that puts ink on tape.
    popts = argparse.ArgumentParser(add_help=False)
    popts.add_argument("--no-cut", action="store_true", help="don't auto-cut after printing")
    popts.add_argument("--mode", choices=sorted(brother_print.MODES),
                       default=brother_print.DEFAULT_MODE, help="print quality mode")

    sp = sub.add_parser("print", parents=[popts], help="print an existing image file")
    sp.add_argument("file")
    sp.set_defaults(func=cmd_print)

    sp = sub.add_parser("send", parents=[popts], help="alias for print (native AppSocket send)")
    sp.add_argument("file")
    sp.set_defaults(func=cmd_send)

    sp = sub.add_parser("text", parents=[popts], help="render and print a plain-text label")
    sp.add_argument("text")
    sp.add_argument("--size", type=int, default=64)
    sp.add_argument("--no-print", action="store_true")
    sp.set_defaults(func=cmd_text)

    sp = sub.add_parser("icon", parents=[popts], help="generate an icon from a prompt and print it")
    sp.add_argument("prompt")
    sp.add_argument("--no-print", action="store_true")
    sp.add_argument("--regen", action="store_true", help="ignore cache, regenerate")
    sp.set_defaults(func=cmd_icon)

    sp = sub.add_parser("drawer", parents=[popts], help="print an icon+text drawer label")
    sp.add_argument("name", help="label text, e.g. 'HDMI Cables'")
    sp.add_argument("--no-print", action="store_true")
    sp.add_argument("--regen", action="store_true", help="regenerate the icon")
    sp.set_defaults(func=cmd_drawer)

    sp = sub.add_parser("tag", parents=[popts], help="print a shelf sticker for an inventory tag (id or name)")
    sp.add_argument("tag")
    sp.add_argument("--no-print", action="store_true")
    sp.add_argument("--regen", action="store_true", help="regenerate the icon")
    sp.set_defaults(func=cmd_tag)
    sub.add_parser("tags", help="list inventory tags").set_defaults(func=cmd_tags)

    sp = sub.add_parser("sheet",
                        help="pack pictograms onto one strip (one cut) — tape-sparing (RFC-002)")
    sp.add_argument("images", nargs="*", help="pictogram image files to pack")
    sp.add_argument("--demo", action="store_true", help="use 6 built-in wireframe glyphs")
    sp.add_argument("--tile", type=float, default=0.45, help='tile size in inches (default 0.45")')
    sp.add_argument("--no-ruler", dest="ruler", action="store_false",
                    help="omit the calibration ruler edge")
    sp.add_argument("--print", dest="do_print", action="store_true",
                    help="actually print the strip (one job, one cut)")
    sp.set_defaults(func=cmd_sheet)

    sp = sub.add_parser("status", help="printer + queue status")
    sp.add_argument("--json", action="store_true",
                    help="one-line machine-readable JSON; exit 0 iff printer is idle")
    sp.set_defaults(func=cmd_status)
    sub.add_parser("reset", help="clear a stuck print job (also detects a delayed"
                   " raster flush — tells you whether to reprint)").set_defaults(func=cmd_reset)
    sub.add_parser("cut", help="explain auto-cut behavior").set_defaults(func=cmd_cut)
    sub.add_parser("waybar", help="emit JSON for a waybar custom module").set_defaults(func=cmd_waybar)

    args = p.parse_args()
    if getattr(args, "no_cut", False):
        PRINT_CUT = "none"
    if getattr(args, "mode", None):
        PRINT_MODE = args.mode
    args.func(args)


if __name__ == "__main__":
    main()
