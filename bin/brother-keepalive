#!/usr/bin/env python3
"""brother-keepalive — poke the VC-500W so it stays on the network.

The printer drops its WiFi association after idle. Status reads normally send
<nokeepawake>1</nokeepawake> ("don't keep awake"); this poke deliberately omits
that flag (keep_awake=True) to hold the printer awake. Runs from a systemd timer
every few minutes. Safe to run when the printer is offline (it just no-ops).
"""

import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent))
import brother_print


def main():
    try:
        blob = brother_print.query("/status.xml", timeout=4.0, keep_awake=True)
        state = brother_print.xml_field(blob, "print_state") or "?"
        print(f"keepalive ok: print_state={state}")
    except OSError as e:
        print(f"keepalive: printer unreachable ({e})")
        # Exit 0 regardless: an offline printer is not a service failure.


if __name__ == "__main__":
    main()
